{
  "DataSources": {
    "DefaultConnectionStrings": {
      "Dev": "Data Source=data;Initial Catalog=DeployTest;Integrated Security=True",
      "Test": "Data Source=data;Initial Catalog=DeployTest;Integrated Security=True",
      "Prod": "Data Source=data;Initial Catalog=DeployTest;Integrated Security=True"
    },
    "Extension": "SQL",
    "CredentialRetrieval": "Integrated"
  },
  "Deployment": {
    "CreateFolders": true,
    "OverwriteExisting": {
      "DataSources": true,
      "DataSets": true,
      "Reports": true
    },
    "CreateDataSources": true,
    "CreateDataSets": true,
    "CreateReports": true
  },
  "ReferenceMappings": {
    "DataSources": {
      "AutoMapping": true,
      "CustomMappings": {}
    },
    "DataSets": {
      "AutoMapping": true,
      "CustomMappings": {}
    }
  },
  "Security": {
    "Authentication": {
      "UseCurrentUser": true,
      "PromptForCredentials": false,
      "Domain": "",
      "Username": ""
    }
  },
  "Environments": {
    "Dev": {
      "ReportServerUrl": "http://data/ReportServer",
      "ReportManagerUrl": "http://data/Reports"
    },
    "Test": {
      "ReportServerUrl": "http://data/ReportServer",
      "ReportManagerUrl": "http://data/Reports"
    },
    "Prod": {
      "ReportServerUrl": "http://data/ReportServer",
      "ReportManagerUrl": "http://data/Reports"
    }
  }
}
